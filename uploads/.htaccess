# مجلد الرفع: منع السرد والسكربتات؛ السماح بعرض صور فقط (بما فيها svg كما طُلب)
# السبب: منع رفع ملف يُنفَّذ كـ PHP أو سكربت، وتقليل تسريب أسماء الملفات

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_FILENAME} -f
    # صور + فيديوهات الواجهة (mp4/webm) — كانت mp4 تُرفض بـ 403
    RewriteCond %{REQUEST_URI} !\.(jpe?g|png|webp|gif|svg|mp4|webm|mov)$ [NC]
    RewriteRule .* - [F,L]
</IfModule>

<IfModule mod_authz_core.c>
    <FilesMatch "\.(?i)(php|phtml|phps|phar|cgi|pl|py|jsp|asp|aspx|sh|exe|bat|cmd)$">
        Require all denied
    </FilesMatch>
</IfModule>

<IfModule mod_php.c>
    php_flag engine off
</IfModule>
