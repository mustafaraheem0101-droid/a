# نسخ إلى .env أو private_data/.env واضبط القيم على السيرفر
# Copy to .env or private_data/.env and set values on the server.

API_DEBUG=0

# عند true: يُعتمد فقط على HTTP_CF_CONNECTING_IP (خلف Cloudflare فقط)
# When true: trust only HTTP_CF_CONNECTING_IP (only behind Cloudflare)
BEHIND_CLOUDFLARE=0

# معدل طلبات API: نافذة وحد أقصى للطلبات (POST — أشد)
RATE_LIMIT_WINDOW=300
RATE_LIMIT_MAX_REQUESTS=250

# GET أخف (افتراضي: 120 طلباً لكل 60 ثانية)
RATE_LIMIT_GET_WINDOW=60
RATE_LIMIT_GET_MAX=120
